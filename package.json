{
  "name": "aixpense-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "APP_VARIANT=development expo start",
    "android": "APP_VARIANT=development expo run:android",
    "prebuild": "APP_VARIANT=development expo prebuild --clean --platform android",
    "fresh": "bun run prebuild && bun run android",
    "build": "eas build --profile production --platform android",
    "release": "eas build --platform android --profile production --auto-submit",
    "update": "eas update --channel production --platform android --environment production",
    "update:preview": "eas update --channel preview --platform android --environment preview",
    "update:production": "eas update --channel production --platform android --environment production",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@better-auth/expo": "^1.4.18",
